# Base domain and hostnames
BASE_DOMAIN=my-domain.com
API_SUBDOMAIN=api
CHAT_SUBDOMAIN=chat

# Public contact email for ACME / Let's Encrypt
LETSENCRYPT_EMAIL=you@example.com

# Shared API key used for all model API paths on api.<BASE_DOMAIN>
MODEL_API_KEY=replace-with-a-long-random-secret

# Optional Hugging Face token for gated/private models
HF_TOKEN=

# BitNet runtime defaults
BITNET_THREADS=4
BITNET_CTX_SIZE=2048
BITNET_N_PREDICT=4096
BITNET_TEMPERATURE=0.8
BITNET_QUANT_TYPE=i2_s

# Default model repos for each backend
BITNET_MODEL_REPO=microsoft/BitNet-b1.58-2B-4T-gguf
FALCON_MODEL_REPO=tiiuae/Falcon3-1B-Instruct-1.58bit

# DDNS configuration (ddclient)
# Required in this repo:
# - DDCLIENT_PROTOCOL
# - DDCLIENT_LOGIN
# - DDCLIENT_PASSWORD
# - DDCLIENT_HOSTS
#
# Optional depending on provider:
# - DDCLIENT_CUSTOM
# - DDCLIENT_SERVER
# - DDCLIENT_SCRIPT
# - DDCLIENT_PROVIDER
# - DDCLIENT_ZONE
# - DDCLIENT_TTL
#
# DDCLIENT_HOSTS is the final host line rendered into ddclient.conf.
# Use a comma-separated list if your provider supports updating multiple hosts.
DDCLIENT_PROTOCOL=provider-protocol
DDCLIENT_LOGIN=account-or-token-name
DDCLIENT_PASSWORD=replace-with-ddns-password-or-api-token
DDCLIENT_HOSTS=api.my-domain.com,chat.my-domain.com
DDCLIENT_USE=web
DDCLIENT_WEB=checkip.dyndns.org/
DDCLIENT_WEB_SKIP="Current IP Address:"
DDCLIENT_SSL=yes
DDCLIENT_DAEMON_SECONDS=300

# Provider-specific optional examples:
# DDCLIENT_CUSTOM=yes
# DDCLIENT_SERVER=dyndns.example.com
# DDCLIENT_SCRIPT=/nic/update
# DDCLIENT_PROVIDER=cloudflare
# DDCLIENT_ZONE=my-domain.com
# DDCLIENT_TTL=300

# LinuxServer container UID/GID
PUID=1000
PGID=1000
TZ=Europe/Stockholm
